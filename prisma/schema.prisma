generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ====== Models ======

model user {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique(map: "User_email_key")
  password  String
  phone     String?
  role      user_role @default(SELLER)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  // Relations
  savedProducts SellerProduct[]
  wallet       wallet?
  logs         log[]
  orders       order[]      @relation("SellerOrders")
  orderBatches orderbatch[] // relation مع orderbatch
  deposits  depositrequest[]
}

model wallet {
  id      String  @id @default(uuid())
  userId  String  @unique(map: "Wallet_userId_key")
  balance Decimal @default(0.0)

  // Relations
  user         user          @relation(fields: [userId], references: [id])
  transactions transaction[]
}

model transaction {
  id          String           @id @default(uuid())
  walletId    String
  amount      Decimal
  type        transaction_type
  referenceId String?
  description String?
  createdAt   DateTime         @default(now())

  wallet wallet @relation(fields: [walletId], references: [id])

  @@index([walletId], map: "Transaction_walletId_idx")
}

model log {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user user @relation(fields: [userId], references: [id])

  @@index([userId], map: "Log_userId_idx")
}

model order {
  id             String       @id @default(uuid())
  sellerId       String
  
  // 1. الربط مع الدفعة (Batch)
  batchId        String?
  batch          orderbatch?  @relation(fields: [batchId], references: [id])

  // 2. الربط مع المنتج (Product)
  productId      String?
  product        product?     @relation(fields: [productId], references: [id])

  customerName   String
  customerPhone  String
  address        String
  city           String
  productName    String
  quantity       Int
  codAmount      Decimal
  status         order_status @default(DRAFT)
  trackingNumber String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  seller user @relation("SellerOrders", fields: [sellerId], references: [id])

  @@index([batchId], map: "Order_batchId_idx")
  @@index([sellerId], map: "Order_sellerId_idx")
  @@index([productId], map: "Order_productId_idx")
}

model orderbatch {
  id           String   @id @default(uuid())
  sellerId     String
  totalAmount  Decimal
  paymentProof String?
  isPaid       Boolean  @default(false)
  createdAt    DateTime @default(now())

  orders       order[]

  seller user @relation(fields: [sellerId], references: [id])

  @@index([sellerId], map: "OrderBatch_sellerId_idx")
}

model SellerProduct {
  id        String   @id @default(cuid())
  sellerId  String
  productId String
  addedAt   DateTime @default(now())

  seller    user     @relation(fields: [sellerId], references: [id])
  product   product  @relation(fields: [productId], references: [id])

  @@unique([sellerId, productId]) 
  @@index([sellerId])
}


model product {
  id          String   @id @default(uuid())
  supplierId  String
  name        String
  description String?  @db.Text
  images      String   @db.LongText
  sku         String   @unique(map: "Product_sku_key")
  costPrice   Decimal
  sellerPrice Decimal
  marketPrice Decimal
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  savedByUsers  SellerProduct[]
  orders      order[]

  supplier supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId], map: "Product_supplierId_idx")
}

model supplier {
  id          String  @id @default(uuid())
  name        String
  contactInfo String?

  products product[]
}

model depositrequest {
  id            String        @id @default(cuid())
  sellerId      String
  amount        Decimal
  receiptImage  String?       // رابط صورة الوصل
  status        deposit_status @default(PENDING)
  notes         String?    
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  seller        user          @relation(fields: [sellerId], references: [id])
}

// ====== Enums ======
enum transaction_type {
  DEPOSIT
  ORDER_PAYMENT
  REFUND_RETURN
  WITHDRAWAL
}

enum deposit_status {
  PENDING
  APPROVED
  REJECTED
}

enum user_role {
  ADMIN
  SELLER
  CALL_CENTER
}

enum order_status {
  DRAFT
  PENDING_CONFIRMATION
  CONFIRMED
  WAITING_PAYMENT
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}
